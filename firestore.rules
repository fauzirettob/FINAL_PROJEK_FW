rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── FUNGSI BANTU ─────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    function hasFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function isString(field) {
      return request.resource.data[field] is string;
    }

    function isTimestamp(field) {
      return request.resource.data[field] is timestamp;
    }

    // ─── COUNTERS ─────────────────────────────────────────
    // Counter dokumen digunakan untuk membatasi jumlah admin maksimal 3
    match /_counters/{counterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── ADMIN ────────────────────────────────────────────
    // Dokumen admin menggunakan UID user sebagai document ID.
    // Admin bisa CRUD; user biasa hanya bisa baca/menulis data dirinya sendiri.
    // Jumlah admin dibatasi maksimal 3 via counter doc (_counters/admin_count).
    match /admin/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();

      allow create: if isOwner(userId)
        && hasFields(['nama', 'email', 'createdAt'])
        && isString('nama')
        && isString('email')
        && isString('role')
        && isTimestamp('createdAt')
        && (
          // Izinkan jika counter dokumen belum ada (admin pertama)
          !exists(/databases/$(database)/documents/_counters/admin_count)
          // Atau jika jumlah admin saat ini < 3
          || get(/databases/$(database)/documents/_counters/admin_count).data.count < 3
        );

      allow update: if isOwner(userId)
        && isString('nama')
        && isString('email')
        && isString('role');
    }

    // ─── GURU ─────────────────────────────────────────────
    // Dokumen guru menggunakan UID user sebagai document ID.
    match /guru/{userId} {
      allow read: if isAuthenticated();
      // Guru bisa daftar sendiri (isOwner); Admin juga bisa create via Cloud Function
      allow create: if (isOwner(userId) || isAdmin())
        && hasFields(['nama', 'email', 'createdAt'])
        && isString('nama')
        && isString('email')
        && isString('role')
        && isTimestamp('createdAt');

      allow update: if isOwner(userId)
        && isString('nama')
        && isString('email');

      allow delete: if isAdmin();
    }

    // ─── SISWA ────────────────────────────────────────────
    match /siswa/{docId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && hasFields(['nama', 'nis', 'kelas', 'namaOrtu', 'hpOrtu', 'createdAt'])
        && isString('nama')
        && isString('nis')
        && isString('kelas')
        && isString('namaOrtu')
        && isString('hpOrtu')
        && isTimestamp('createdAt');

      allow update: if isAuthenticated()
        && isString('nama')
        && isString('nis')
        && isString('kelas');

      allow delete: if isAuthenticated();
    }

    // ─── ABSENSI ──────────────────────────────────────────
    match /absensi/{docId} {
      allow read: if isAuthenticated();

      allow create: if isAuthenticated()
        && hasFields(['siswaId', 'siswaNama', 'kelas', 'tanggal', 'status', 'jam', 'guruId'])
        && isString('siswaId')
        && isString('siswaNama')
        && isString('kelas')
        && isTimestamp('tanggal')
        && isString('status')
        && isString('jam')
        && isString('guruId')
        && request.resource.data['status'] in ['hadir', 'izin', 'sakit', 'alpa'];

      allow update: if isAuthenticated()
        && isString('status')
        && request.resource.data['status'] in ['hadir', 'izin', 'sakit', 'alpa'];

      allow delete: if isAuthenticated();
    }

    // ─── KELAS LOCKS ────────────────────────────────────────
    // Digunakan oleh fitur kunci absensi kelas
    match /kelas_locks/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && hasFields(['kelas', 'tanggal', 'isLocked', 'lockedAt', 'lockedBy'])
        && isString('kelas')
        && isTimestamp('tanggal')
        && isString('lockedBy');
      allow write: if isAuthenticated();
    }

    // ─── KELAS NOTIFIKASI ───────────────────────────────────
    // Digunakan untuk menandai notifikasi kelas sudah dikirim
    match /kelas_notifikasi/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && hasFields(['kelas', 'tanggal', 'dikirim', 'dikirimAt'])
        && isString('kelas')
        && isTimestamp('tanggal');
      allow write: if isAuthenticated();
    }

    // ─── DENY ─────────────────────────────────────────────
    // Tolak semua akses ke koleksi lain yang tidak didefinisikan
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
